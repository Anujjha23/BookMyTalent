# ─────────────────────────────────────────────
#  ARTWAVE — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# JWT Secret — change this to a long random string in production!
JWT_SECRET=artwave_super_secret_change_me_in_production_2026

# CORS — frontend origin (comma-separated for multiple)
FRONTEND_URL=http://localhost:3000

# Optional: MongoDB connection string (if you upgrade from in-memory store)
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/artwave

# Optional: Cloudinary for media uploads
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
